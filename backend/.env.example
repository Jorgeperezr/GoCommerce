# Plantilla de configuración. Copia este archivo como .env y rellena los valores:
#   cp .env.example .env
#   openssl rand -hex 32   # para generar SECRET_KEY

# Servidor
PORT=8080

# Base de Datos (sqlite | postgres)
DB_DIALECT=sqlite
DB_NAME=gocommerce.db
# Solo para postgres:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=secret

# JWT: clave obligatoria, el servidor no arranca sin ella
SECRET_KEY=
